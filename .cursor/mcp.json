{
  "mcpServers": {
    "actant": {
      "command": "npx",
      "args": ["tsx", "packages/mcp-server/src/index.ts"],
      "env": {
        "ACTANT_AGENT_NAME": "cursor-dev"
      }
    },
    "gitnexus": {
      "command": "npx",
      "args": ["-y", "gitnexus@latest", "mcp"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "webdev": {
      "command": "npx",
      "args": ["-y", "webdev-mcp@latest"]
    }
  }
}
