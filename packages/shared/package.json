{
  "name": "@actant/shared",
  "version": "0.5.0",
  "description": "Shared utilities and types for Actant's ContextFS baseline",
  "type": "module",
  "license": "MIT",
  "author": "blackplume <blackplume233@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/blackplume233/Actant.git",
    "directory": "packages/shared/core"
  },
  "homepage": "https://github.com/blackplume233/Actant#readme",
  "bugs": "https://github.com/blackplume233/Actant/issues",
  "keywords": [
    "actant",
    "ai-agent",
    "shared"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./vfs-contracts": {
      "import": "./dist/vfs-contracts.js",
      "types": "./dist/vfs-contracts.d.ts"
    },
    "./runtime-contracts": {
      "import": "./dist/runtime-contracts.js",
      "types": "./dist/runtime-contracts.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/core.ts src/vfs-contracts.ts src/runtime-contracts.ts",
    "dev": "tsup --watch",
    "type-check": "tsc -b --pretty false",
    "test": "vitest run",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0"
  }
}
