{
  "name": "@actant/domain-context",
  "version": "0.5.0",
  "description": "Domain context management: component managers, templates, builders, and providers for the Actant platform",
  "type": "module",
  "license": "MIT",
  "author": "blackplume <blackplume233@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/blackplume233/Actant.git",
    "directory": "packages/domain-context"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
