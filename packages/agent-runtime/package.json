{
  "name": "@actant/agent-runtime",
  "version": "0.5.0",
  "description": "Agent runtime resources for Actant's ContextFS baseline",
  "type": "module",
  "license": "MIT",
  "author": "blackplume <blackplume233@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/blackplume233/Actant.git",
    "directory": "packages/agent-runtime"
  },
  "homepage": "https://github.com/blackplume233/Actant#readme",
  "bugs": "https://github.com/blackplume233/Actant/issues",
  "keywords": [
    "actant",
    "ai-agent",
    "core",
    "runtime"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "type-check": "tsc -b --pretty false",
    "test": "vitest run",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@actant/domain-context": "workspace:0.5.0",
    "@actant/shared": "workspace:0.5.0",
    "@actant/source": "workspace:0.5.0",
    "@actant/vfs": "workspace:0.5.0",
    "croner": "^9.0.0",
    "picomatch": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.2"
  }
}
