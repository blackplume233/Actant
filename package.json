{
  "name": "actant-monorepo",
  "version": "0.5.0",
  "private": true,
  "description": "Actant monorepo for the ContextFS baseline and VFS Kernel implementation",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/blackplume233/Actant.git"
  },
  "homepage": "https://github.com/blackplume233/Actant#readme",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @actant/cli run dev",
    "dev:actant": "node scripts/run-workspace-entry.mjs packages/cli/src/bin/actant.ts",
    "dev:acthub": "node scripts/run-workspace-entry.mjs packages/cli/src/bin/acthub.ts",
    "dev:mcp": "node scripts/run-workspace-entry.mjs packages/mcp-server/src/index.ts",
    "test:bootstrap": "node scripts/context-smoke.mjs",
    "test:context": "pnpm run test:bootstrap",
    "test:e2e:vitest": "vitest run packages/cli/src/__tests__/e2e-cli.test.ts packages/mcp-server/src/context-backend.test.ts packages/api/src/handlers/__tests__/gateway-handlers.test.ts packages/api/src/handlers/__tests__/error-contract.test.ts packages/vfs/src/__tests__/m5-control-stream-e2e.test.ts packages/vfs/src/__tests__/m5-filesystem-type-features-e2e.test.ts packages/vfs/src/__tests__/m6-facade-e2e.test.ts",
    "test:e2e": "pnpm run test:e2e:vitest && pnpm run test:bootstrap",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:endurance": "vitest run --config vitest.endurance.config.ts",
    "test:watch": "vitest",
    "check": "pnpm run type-check && vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "pnpm -r run type-check",
    "clean": "pnpm -r run clean",
    "build:standalone": "node scripts/build-standalone.mjs",
    "build:standalone:bundle-only": "node scripts/build-standalone.mjs --bundle-only",
    "publish:dry": "pnpm build && pnpm -r publish --dry-run --no-git-checks",
    "publish:all": "pnpm build && pnpm -r publish --no-git-checks",
    "version:sync": "node scripts/version-sync.mjs",
    "install:local": "node scripts/install-local.mjs",
    "install:local:standalone": "node scripts/install-local.mjs --standalone"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "author": "blackplume <blackplume233@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "playwright": "^1.58.2",
    "postject": "1.0.0-alpha.6",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
